paper/*.aux
paper/*.log
paper/*.out
paper/*.bbl
paper/*.blg
paper/*.synctex.gz
paper/*.fdb_latexmk
paper/*.fls
paper/page-*.png
paper/build*.log
texput.log
paper/main_text.txt
